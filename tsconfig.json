{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "resolvePackageJsonExports": false,
    "target": "esnext",
    "baseUrl": "./src",
    "paths": {
      "~/*": [
        "*"
      ]
    },
    "types": [
      "react-native",
      "node"
    ],
    "lib": [
      "es2023",
      "dom"
    ]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}